menu "Wi-Fi config"

choice ESP_WIFI_TASK_CORE_ID
	prompt "WiFi Task Core ID"
	depends on SOC_SERIES_ESP32S3
	default ESP_WIFI_TASK_PINNED_TO_CORE_0
	help
	  Pinned WiFi task to core 0 or core 1.

