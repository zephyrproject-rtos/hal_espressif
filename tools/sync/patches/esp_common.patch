-#endif
-#ifndef unlikely
 #define unlikely(x)    __builtin_expect(!!(x), 0)
-#endif
 #else
-#ifndef likely
 #define likely(x)      (x)
-#endif
-#ifndef unlikely
 #define unlikely(x)    (x)
 #endif
 #endif
